# Project Configuration
PROJECT_NAME="Chatbot API"
VERSION="0.1.0"
HOST="0.0.0.0"
PORT=8000

# Logging Configuration
LOG_LEVEL="INFO"

# CORS Configuration
# JSON list of allowed origins. For LAN deployment, add the server's
# LAN URL (the address the client browser sees), e.g.
#   CORS_ORIGINS=["http://192.168.1.10:5173","http://192.168.1.10:8000"]
# A single "*" disables the whitelist (allow_credentials forced off).
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Optional: JSON list of regex patterns matched against Origin. Handy to
# accept any port on a LAN subnet without enumerating ports.
# 推荐配置（放行所有内网网段：10.x / 172.16-31.x / 192.168.x，任意端口）：
# CORS_ORIGIN_REGEX=["http://(10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}|172\\.(1[6-9]|2[0-9]|3[01])\\.\\d{1,3}\\.\\d{1,3}|192\\.168\\.\\d{1,3}\\.\\d{1,3})(:\\d{1,5})?"]
CORS_ORIGIN_REGEX=[]

# DeepSeek API Configuration
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_API_KEY=""
AUTH_SECRET_KEY="replace-with-a-random-secret"

# 注册邀请码：留空 = 任何人可注册；非空 = 注册时必须填且匹配
# 推荐内网/多人场景下随机生成一个，用：python -c "import secrets; print(secrets.token_urlsafe(9))"
REGISTRATION_INVITE_CODE=""

# LLM Model Configuration
MODEL="deepseek-v4-flash"
MAX_NEW_TOKENS=512

# Retrieval Configuration
EMBEDDING_MODEL="jinaai/jina-embeddings-v5-text-small-retrieval"
SYNTHESIS_STRATEGY="tree-summarization"
NUM_RETRIEVALS=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=50

# Chat History Configuration
CHAT_HISTORY_LENGTH=2

# WebSocket Configuration
WEBSOCKET_MAX_SIZE=10485760

# File Upload Configuration
ALLOWED_UPLOAD_EXTENSIONS=[".md",".pdf"]
